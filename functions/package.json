{
  "name": "turqappv2-functions",
  "engines": {
    "node": "22"
  },
  "private": true,
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p .",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/unit/**/*.test.js",
    "test:rules": "firebase emulators:exec --project demo-turqapp --only firestore,storage \"node --test tests/rules/**/*.test.js\"",
    "deploy": "firebase deploy --only functions",
    "serve": "firebase emulators:start --only functions"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.3.0",
    "axios": "^1.13.5",
    "firebase-admin": "^11.11.1",
    "firebase-functions": "^4.9.0",
    "resend": "^4.0.1",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.2",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.3",
    "@types/express-serve-static-core": "^5.0.7",
    "@types/glob": "^8.1.0",
    "@types/ms": "^2.1.0",
    "@types/qs": "^6.14.0",
    "@types/range-parser": "^1.2.7",
    "@types/send": "^0.17.5",
    "@types/serve-static": "^1.15.8",
    "firebase": "^10.14.1",
    "firebase-tools": "^13.30.0",
    "typescript": "^5.4.0"
  }
}
