rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function ownerMatches(data, key) {
      return data.keys().hasAny([key])
        && data[key] is string
        && data[key] == request.auth.uid;
    }
    function isOwnerData(data) {
      return ownerMatches(data, 'userID')
        || ownerMatches(data, 'userId')
        || ownerMatches(data, 'uid')
        || ownerMatches(data, 'ownerId')
        || ownerMatches(data, 'ownerID');
    }
    function isDocOwnerFromRequest() {
      return isAuth() && isOwnerData(request.resource.data);
    }
    function isDocOwnerFromResource() {
      return isAuth() && isOwnerData(resource.data);
    }
    function isAdmin() {
      return isAuth() && request.auth.token.admin == true;
    }
    function isBlackBadge() {
      return isAuth()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rozet == 'siyah'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rozet == 'Siyah'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rozet == 'black'
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rozet == 'Black'
        );
    }
    function moderationClientKeys() {
      return [
        'flagCount', 'flaggedBy', 'reasonsSummary', 'status',
        'thresholdReachedAt', 'shadowHiddenAt', 'lastFlagAt', 'ownerNotified'
      ];
    }
    function moderationReasonKeys() {
      return ['drugs', 'gambling', 'nudity', 'scam', 'violence', 'spam', 'other'];
    }
    function isAllowedModerationStatus(v) {
      return v in ['active', 'shadow_hidden'];
    }
    function canFlagPostModerationUpdate() {
      return isBlackBadge()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['moderation'])
        && request.resource.data.moderation is map
        && (
          (
            resource.data.moderation is map
            && request.resource.data.moderation.diff(resource.data.moderation)
                 .affectedKeys().hasOnly(moderationClientKeys())
          )
          || (
            !resource.data.keys().hasAny(['moderation'])
            && request.resource.data.moderation.keys().hasOnly(moderationClientKeys())
          )
        )
        && request.resource.data.moderation.flagCount is int
        && request.resource.data.moderation.flagCount >= 1
        && request.resource.data.moderation.flaggedBy is list
        && request.auth.uid in request.resource.data.moderation.flaggedBy
        && request.resource.data.moderation.lastFlagAt is int
        && (!request.resource.data.moderation.keys().hasAny(['thresholdReachedAt'])
          || request.resource.data.moderation.thresholdReachedAt is int)
        && (!request.resource.data.moderation.keys().hasAny(['shadowHiddenAt'])
          || request.resource.data.moderation.shadowHiddenAt is int)
        && (!request.resource.data.moderation.keys().hasAny(['ownerNotified'])
          || request.resource.data.moderation.ownerNotified is bool)
        && (!request.resource.data.moderation.keys().hasAny(['status'])
          || isAllowedModerationStatus(request.resource.data.moderation.status))
        && (!request.resource.data.moderation.keys().hasAny(['reasonsSummary'])
          || (
            request.resource.data.moderation.reasonsSummary is map
            && request.resource.data.moderation.reasonsSummary.keys().hasOnly(moderationReasonKeys())
          ))
        && (
          !resource.data.keys().hasAny(['moderation'])
          || !(
            resource.data.moderation is map
            && resource.data.moderation.keys().hasAny(['flaggedBy'])
            && resource.data.moderation.flaggedBy is list
            && request.auth.uid in resource.data.moderation.flaggedBy
          )
        );
    }
    function isAllowlistedPushSender() {
      return isAuth()
        && exists(/databases/$(database)/documents/adminConfig/admin)
        && get(/databases/$(database)/documents/adminConfig/admin).data.pushSend == true
        && get(/databases/$(database)/documents/adminConfig/admin).data.allowedUserIds is list
        && request.auth.uid in get(/databases/$(database)/documents/adminConfig/admin).data.allowedUserIds;
    }
    function canUseAdminPushBypass() {
      return isAdmin() || isAllowlistedPushSender();
    }
    function isFollowerEdgeWrite(followerId) {
      return isAuth()
        && request.auth.uid == followerId
        && request.resource.data.keys().hasOnly(['timeStamp'])
        && request.resource.data.timeStamp is int;
    }
    function isFollowingEdgeWrite(uid) {
      return isOwner(uid)
        && request.resource.data.keys().hasOnly(['timeStamp'])
        && request.resource.data.timeStamp is int;
    }
    function isAllowedNotificationType(v) {
      return v in [
        'Posts', 'posts', 'Comment', 'comment',
        'like', 'reshared_posts', 'shared_as_posts',
        'job_application', 'tutoring_application', 'tutoring_status',
        'chat', 'message', 'follow', 'user', 'User', 'Chat'
      ];
    }
    function isActiveSender(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.isBanned != true
        && get(/databases/$(database)/documents/users/$(uid)).data.isDeleted != true;
    }
    function canCreateNotification(uid) {
      return canUseAdminPushBypass()
        || (isAuth()
          && request.auth.uid != uid
          && request.resource.data.fromUserID == request.auth.uid
          && isActiveSender(request.auth.uid)
          && (!request.resource.data.keys().hasAny(['hideInAppInbox'])
            || request.resource.data.hideInAppInbox != true)
          && (!request.resource.data.keys().hasAny(['adminPush'])
            || request.resource.data.adminPush != true));
    }
    function isValidNotificationPayload(uid) {
      return request.resource.data.keys().hasOnly([
          'type', 'fromUserID', 'postID', 'timeStamp', 'read',
          'title', 'body', 'imageUrl', 'adminPush', 'hideInAppInbox',
          'isRead', 'postType', 'thumbnail', 'userID', 'desc'
        ])
        && request.resource.data.keys().hasAll(['type', 'fromUserID', 'timeStamp'])
        && request.resource.data.type is string
        && request.resource.data.type.size() > 0
        && request.resource.data.type.size() <= 64
        && isAllowedNotificationType(request.resource.data.type)
        && request.resource.data.fromUserID is string
        && request.resource.data.fromUserID.size() > 0
        && request.resource.data.fromUserID.size() <= 128
        && request.resource.data.timeStamp is int
        && request.resource.data.fromUserID != uid
        && request.resource.data.timeStamp > 0
        && request.resource.data.timeStamp <= request.time.toMillis() + 900000
        && (!request.resource.data.keys().hasAny(['postID'])
          || (request.resource.data.postID is string
            && request.resource.data.postID.size() <= 256))
        && (!request.resource.data.keys().hasAny(['read']) || request.resource.data.read is bool)
        && (!request.resource.data.keys().hasAny(['title'])
          || (request.resource.data.title is string
            && request.resource.data.title.size() <= 160))
        && (!request.resource.data.keys().hasAny(['body'])
          || (request.resource.data.body is string
            && request.resource.data.body.size() <= 4000))
        && (!request.resource.data.keys().hasAny(['imageUrl'])
          || (request.resource.data.imageUrl is string
            && request.resource.data.imageUrl.size() <= 4096))
        && (!request.resource.data.keys().hasAny(['adminPush']) || request.resource.data.adminPush is bool)
        && (!request.resource.data.keys().hasAny(['hideInAppInbox']) || request.resource.data.hideInAppInbox is bool)
        && (!request.resource.data.keys().hasAny(['isRead']) || request.resource.data.isRead is bool)
        && (!request.resource.data.keys().hasAny(['postType']) || request.resource.data.postType is string)
        && (!request.resource.data.keys().hasAny(['thumbnail'])
          || (request.resource.data.thumbnail is string
            && request.resource.data.thumbnail.size() <= 4096))
        && (!request.resource.data.keys().hasAny(['userID'])
          || (request.resource.data.userID is string && request.resource.data.userID == uid))
        && (!request.resource.data.keys().hasAny(['desc'])
          || (request.resource.data.desc is string
            && request.resource.data.desc.size() <= 4000));
    }
    function isValidUsernameLower(v) {
      return v is string
        && v.size() >= 3
        && v.size() <= 30
        && v.matches('^[a-z0-9._]+$');
    }

    // ──────────────────────────────────────────────
    // USERS
    // ──────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      // Kullanıcı kendi profilini güncelleyebilir; ancak moderasyon, rol ve
      // sayaç alanlarını client değiştiremez.
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'role', 'admin',
          'isBanned', 'isDeleted', 'isApproved', 'isBot', 'isAdvertiser',
          'accountStatus', 'deletedAt',
          'takipciSayisi', 'takipEdilenSayisi', 'gonderSayisi',
          'followerCount', 'followingCount', 'postCount',
          'counterOfFollowers', 'counterOfFollowings', 'counterOfPosts'
        ]);
      allow delete: if false;

      // followers (followers)
      match /followers/{followerId} {
        allow read: if isAuth();
        allow create: if isFollowerEdgeWrite(followerId) || isAdmin();
        allow update: if isAdmin();
        allow delete: if isAuth() && (request.auth.uid == followerId || request.auth.uid == uid);
      }

      // followings (following)
      match /followings/{followingId} {
        allow read: if isAuth();
        allow create: if isFollowingEdgeWrite(uid);
        allow update: if isAdmin();
        allow delete: if isOwner(uid);
      }

      // Notifications
      match /notifications/{notifId} {
        allow read: if isOwner(uid);
        allow create: if canCreateNotification(uid) && isValidNotificationPayload(uid);
        allow update, delete: if isOwner(uid);
      }

      // Canonical user sub-docs
      match /private/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /education/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /family/{docId} {
        allow read, write: if isOwner(uid);
      }
      match /stats/{docId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid) || isAdmin();
      }
      match /settings/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Canonical growing sets as subcollections
      match /blockedUsers/{otherUid} {
        allow read, write: if isOwner(uid);
      }
      match /readStories/{storyId} {
        allow read, write: if isOwner(uid);
      }
      match /lastSearches/{searchId} {
        allow read, write: if isOwner(uid);
      }
      match /chatArchives/{chatId} {
        allow read, write: if isOwner(uid);
      }
      match /chatDeletions/{chatId} {
        allow read, write: if isOwner(uid);
      }
      match /highlights/{highlightId} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }

      // User interaction subcollections
      match /liked_posts/{postId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
      // Social media links (profile)
      match /SosyalMedyaLinkleri/{docId} {
        allow read: if isAuth();
        allow write: if isOwner(uid);
      }
      match /saved_posts/{postId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
      match /commented_posts/{postId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
      match /reshared_posts/{postId} {
        allow read: if isOwner(uid);
        allow write: if isOwner(uid);
      }
      match /qProgress/{categoryKey} {
        allow read, write: if isOwner(uid);
      }
      match /qAnswers/{questionId} {
        allow read, write: if isOwner(uid);
      }
      match /qSaved/{questionId} {
        allow read, write: if isOwner(uid);
      }
      match /qViews/{questionId} {
        allow read, write: if isOwner(uid);
      }

      // DeletedStories archive
      match /DeletedStories/{storyId} {
        allow read: if isOwner(uid);
        allow write: if false; // Admin SDK only
      }

      // Tutoring applications
      match /myTutoringApplications/{docId} {
        allow read, write: if isOwner(uid);
      }

      // Education results (dual-write targets)
      match /examResults/{examId} {
        allow read, write: if isOwner(uid);
      }
      match /bookletResults/{bookId} {
        allow read, write: if isOwner(uid);
      }

      // Stats (follow rate limiting)
      match /Stats/{statId} {
        allow read, write: if false; // Legacy path disabled
      }

      // Unknown subcollections are denied by default.
      match /{anySubcollection}/{docId} {
        allow read, write: if false;
      }
    }

    // Username reservation (uniqueness lock)
    match /users_usernames/{usernameLower} {
      allow read: if isAuth();
      allow create: if isAuth()
        && isValidUsernameLower(usernameLower)
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/users_usernames/$(usernameLower));
      allow update: if isAuth()
        && isValidUsernameLower(usernameLower)
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Ad center (owner + admin). Reports write-side is server only.
    match /adCampaigns/{campaignId} {
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow create: if isAuth()
        && (isAdmin() || request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAuth()
        && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }
    match /adCreatives/{creativeId} {
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow create: if isAuth()
        && (isAdmin() || request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAuth()
        && (isAdmin() || resource.data.ownerId == request.auth.uid);
    }
    match /adPlacements/{placementId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /adImpressions/{docId} {
      allow create: if isAuth();
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow update, delete: if false;
    }
    match /adClicks/{docId} {
      allow create: if isAuth();
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow update, delete: if false;
    }
    match /adBudgets/{docId} {
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow write: if isAuth() && (isAdmin() || request.resource.data.ownerId == request.auth.uid);
    }
    match /adReportsDaily/{docId} {
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /adBilling/{docId} {
      allow read: if isAuth() && (isAdmin() || resource.data.ownerId == request.auth.uid);
      allow write: if isAdmin();
    }

    // New Ads Center (admin internal only)
    match /ads_campaigns/{campaignId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /ads_creatives/{creativeId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /ads_advertisers/{advertiserId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /ads_targeting_index/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /ads_delivery_logs/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Cloud Functions only
    }

    match /ads_impressions/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Cloud Functions only
    }

    match /ads_clicks/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Cloud Functions only
    }

    match /ads_daily_stats/{docId} {
      allow read: if isAdmin();
      allow create, update, delete: if false; // Cloud Functions only
    }

    match /system_flags/{docId} {
      allow read, write: if isAdmin();
    }

    // ──────────────────────────────────────────────
    // POSTS
    // ──────────────────────────────────────────────
    match /Posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userID == request.auth.uid;
      // Sahip: tüm alanları güncelleyebilir (istatistik alanları hariç — bunlar CF yazar)
      // Diğer kullanıcılar: yalnızca izin verilen istatistik sayaçlarını yazabilir
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || canFlagPostModerationUpdate()
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'goruntulenmeSayisi', 'viewCount', 'seenCount',
             'begeniSayisi', 'likeCount',
             'yorumSayisi', 'commentCount',
             'kaydetmeSayisi', 'savedCount',
             'paylasilmaSayisi', 'shareCount'
           ])
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stats'])
          && request.resource.data.stats is map
          && (
            (
              resource.data.stats is map
              && request.resource.data.stats.diff(resource.data.stats).affectedKeys().hasOnly([
                'statsCount', 'likeCount', 'commentCount',
                'savedCount', 'retryCount', 'reportedCount'
              ])
            )
            || (
              !resource.data.keys().hasAny(['stats'])
              && request.resource.data.stats.keys().hasOnly([
                'statsCount', 'likeCount', 'commentCount',
                'savedCount', 'retryCount', 'reportedCount'
              ])
            )
          )
        )
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;

      // Likes
      match /likes/{likeId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
        allow delete: if isAuth() && request.auth.uid == likeId;
      }

      // Comments
      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update: if isAuth() && resource.data.userID == request.auth.uid;
        allow delete: if isAuth() && resource.data.userID == request.auth.uid;

        // Sub-comments (replies)
        match /sub_comments/{replyId} {
          allow read: if isAuth();
          allow create: if isAuth();
          allow update: if isAuth() && resource.data.userID == request.auth.uid;
          allow delete: if isAuth() && resource.data.userID == request.auth.uid;
        }
      }

      // Saveds
      match /saveds/{savedId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == savedId;
      }

      // Reshares
      match /reshares/{reshareId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == reshareId;
      }

      // Reporters
      match /reporters/{reporterId} {
        allow read: if false;
        allow create: if isAuth() && request.auth.uid == reporterId;
        allow delete: if false;
      }

      // Viewers
      match /viewers/{viewerId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
        allow delete: if false;
      }
      match /Viewers/{viewerId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
        allow delete: if false;
      }
    }

    // ──────────────────────────────────────────────
    // STORIES
    // ──────────────────────────────────────────────
    match /Stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      match /likes/{likeId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
      match /viewers/{viewerId} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }
    match /stories/{storyId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && request.resource.data.reactions is map
        )
      );
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      match /likes/{likeId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == likeId;
      }

      match /viewers/{viewerId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == viewerId;
      }

      match /Viewers/{viewerId} {
        allow read: if isAuth();
        allow write: if isAuth() && request.auth.uid == viewerId;
      }

      match /Yorumlar/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.userID == request.auth.uid;
        allow update, delete: if isAuth()
          && resource.data.userID == request.auth.uid;
      }
    }

    // ──────────────────────────────────────────────
    // CHAT / MESSAGING
    // ──────────────────────────────────────────────
    // Legacy Chat koleksiyonu — her iki taraf da erişebilir
    match /Chat/{chatId} {
      function isChatParticipant() {
        return isAuth() && (
          request.auth.uid == resource.data.userID1 ||
          request.auth.uid == resource.data.userID2 ||
          (resource.data.participants is list &&
           request.auth.uid in resource.data.participants)
        );
      }
      function isChatParticipantFromRequest() {
        return isAuth() && (
          request.auth.uid == request.resource.data.userID1 ||
          request.auth.uid == request.resource.data.userID2 ||
          (request.resource.data.participants is list &&
           request.auth.uid in request.resource.data.participants)
        );
      }
      allow read, update, delete: if isChatParticipant();
      allow create: if isChatParticipantFromRequest();
    }
    match /conversations/{conversationId} {
      function hasValidParticipantsFromRequest() {
        return request.resource.data.participants is list
          && request.resource.data.participants.size() == 2
          && request.auth.uid in request.resource.data.participants;
      }
      function hasParticipantsInResource() {
        return request.auth.uid in resource.data.participants;
      }
      function isParticipantFromResource() {
        return isAuth() && hasParticipantsInResource();
      }
      function isLegacyParticipantFromResource() {
        return isAuth() &&
          (
            (resource.data.userID1 is string && request.auth.uid == resource.data.userID1) ||
            (resource.data.userID2 is string && request.auth.uid == resource.data.userID2)
          );
      }
      function isParticipantFromResourceOrLegacy() {
        return isParticipantFromResource()
          || isLegacyParticipantFromResource()
          || isParticipantFromConversationId();
      }
      function isParticipantFromConversationId() {
        return isAuth()
          && conversationId.matches('.*' + request.auth.uid + '.*');
      }
      function isParticipantFromRequest() {
        return isAuth() &&
          hasValidParticipantsFromRequest();
      }
      function canBackfillParticipants() {
        return hasValidParticipantsFromRequest()
          && request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants'])
          && (
            !resource.data.keys().hasAny(['userID1'])
            || !(resource.data.userID1 is string)
            || resource.data.userID1 in request.resource.data.participants
          )
          && (
            !resource.data.keys().hasAny(['userID2'])
            || !(resource.data.userID2 is string)
            || resource.data.userID2 in request.resource.data.participants
          );
      }
      function isParticipantFromConversationDoc() {
        return isParticipantFromConversationId()
          || (
            isAuth() &&
            exists(/databases/$(database)/documents/conversations/$(conversationId)) &&
            (
              (
                get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list
                && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
              )
              || (
                get(/databases/$(database)/documents/conversations/$(conversationId)).data.userID1 is string
                && request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.userID1
              )
              || (
                get(/databases/$(database)/documents/conversations/$(conversationId)).data.userID2 is string
                && request.auth.uid == get(/databases/$(database)/documents/conversations/$(conversationId)).data.userID2
              )
            )
          );
      }

      allow create: if isParticipantFromRequest();
      allow list: if isParticipantFromResource();
      allow get: if isParticipantFromResourceOrLegacy();
      allow delete: if false;
      allow update: if isParticipantFromResourceOrLegacy()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage', 'lastMessageAt', 'lastMessageAtMs', 'lastSenderId',
          'unread', 'typing', 'archived', 'muted', 'pinned', 'chatBg',
          'participants', 'userID1', 'userID2'
        ])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['lastSenderId'])
          || request.resource.data.lastSenderId == request.auth.uid)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['userID1'])
          || request.resource.data.userID1 is string)
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['userID2'])
          || request.resource.data.userID2 is string);

      match /messages/{messageId} {
        function isSender() {
          return request.auth.uid == resource.data.senderId;
        }
        function validMessageCreate() {
          return request.resource.data.senderId == request.auth.uid
            && request.resource.data.createdDate is int
            && request.resource.data.createdDate > 0
            && request.resource.data.keys().hasAll(['senderId', 'createdDate', 'type', 'seenBy'])
            && request.resource.data.seenBy is list
            && request.auth.uid in request.resource.data.seenBy;
        }
        function senderEditableKeys() {
          return [
            'text', 'isEdited', 'unsent', 'mediaUrls', 'location', 'contact',
            'postRef', 'videoUrl', 'videoThumbnail', 'audioUrl', 'audioDurationMs',
            'replyTo', 'status', 'isDeleted'
          ];
        }
        function participantEditableKeys() {
          return ['seenBy', 'status', 'reactions', 'likes', 'deletedFor', 'isStarred'];
        }
        allow read: if isParticipantFromConversationDoc();
        allow create: if isParticipantFromConversationDoc() && validMessageCreate();
        allow update: if isParticipantFromConversationDoc() && (
          (isSender() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(senderEditableKeys()))
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly(participantEditableKeys())
        );
        allow delete: if false;
      }
    }
    match /message/{chatId} {
      function isLegacyParticipant() {
        return isAuth() && (
          request.auth.uid == resource.data.userID1 ||
          request.auth.uid == resource.data.userID2 ||
          (resource.data.participants is list &&
           request.auth.uid in resource.data.participants)
        );
      }
      function isLegacyParticipantFromRequest() {
        return isAuth() && (
          request.auth.uid == request.resource.data.userID1 ||
          request.auth.uid == request.resource.data.userID2 ||
          (request.resource.data.participants is list &&
           request.auth.uid in request.resource.data.participants)
        );
      }

      allow create, update, delete: if false;
      allow read: if isLegacyParticipant();
      match /Chat/{msgId} {
        function legacyParent() {
          return get(/databases/$(database)/documents/message/$(chatId));
        }
        function isLegacyParentParticipant() {
          return isAuth() && (
            request.auth.uid == legacyParent().data.userID1 ||
            request.auth.uid == legacyParent().data.userID2 ||
            (legacyParent().data.participants is list &&
             request.auth.uid in legacyParent().data.participants)
          );
        }
        allow create, update, delete: if false;
        allow read: if isLegacyParentParticipant();
      }
    }

    // ──────────────────────────────────────────────
    // EDUCATION
    // ──────────────────────────────────────────────

    // Legacy soru bankası (eski koleksiyon)
    match /SoruBankasi/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userID == request.auth.uid;
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;
      // Alt koleksiyonlar: yalnızca belge sahibi yazabilir
      match /{sub}/{subDocId} {
        allow read: if isAuth();
        allow write: if isAuth()
          && get(/databases/$(database)/documents/SoruBankasi/$(docId)).data.userID == request.auth.uid;
      }
    }

    // Soru Bankası (yeni)
    match /questionBank/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Sahip tüm alanları düzenleyebilir; diğer kullanıcılar sadece
      // counter/beğeni alanlarını güncelleyebilir
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['viewCount', 'correctCount', 'wrongCount', 'begeniler'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;

      match /Yorumlar/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow update, delete: if isAuth() && resource.data.userID == request.auth.uid;
      }
    }

    // Soru Bankası Skor Tablosu - yalnızca kendi kaydını oluşturabilir
    match /questionBankSkor/{monthKey} {
      allow read: if isAuth();
      allow create, update: if false; // Cloud Functions only
      allow delete: if false;
      match /items/{userId} {
        allow read: if isAuth();
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if false;
      }
    }

    // Burslar (root yerine katalog altı)
    match /catalog/{catalogId}/scholarships/{docId} {
      allow read: if isAuth() && catalogId == "education";
      allow create: if isAuth()
        && catalogId == "education"
        && request.resource.data.userID == request.auth.uid;
      allow update: if isAuth() && catalogId == "education" && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly([
             'begeniler',
             'kaydedenler',
             'goruntuleme',
             'applicationCount',
             'likesCount',
             'bookmarksCount'
           ])
      );
      allow delete: if isAuth() && catalogId == "education" && resource.data.userID == request.auth.uid;

      match /Basvurular/{applicantId} {
        allow read: if isAuth() && catalogId == "education";
        allow create: if isOwner(applicantId) && catalogId == "education";
        allow update: if isAuth() && catalogId == "education" && (
          request.auth.uid == applicantId
          || get(/databases/$(database)/documents/catalog/$(catalogId)/scholarships/$(docId)).data.userID == request.auth.uid
        );
        allow delete: if isOwner(applicantId) && catalogId == "education";
      }
    }

    // Online Testler
    match /Testler/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['katilimciSayisi', 'goruntulenmeSayisi'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;
      // Alt koleksiyonlar: yalnızca test sahibi ya da katılımcı kendi kaydını yönetir
      match /Katilimcilar/{userId} {
        allow read: if isAuth();
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId)
          || get(/databases/$(database)/documents/Testler/$(docId)).data.userID == request.auth.uid;
      }
      match /Sorular/{soruId} {
        allow read: if isAuth();
        allow write: if isAuth()
          && get(/databases/$(database)/documents/Testler/$(docId)).data.userID == request.auth.uid;
      }
    }

    // Deneme Sınavları
    match /practiceExams/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userID == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['participantCount', 'viewCount'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;

      // Sınav soruları - sadece sınav sahibi yazabilir
      match /Sorular/{soruId} {
        allow read: if isAuth();
        allow write: if isAuth() &&
          get(/databases/$(database)/documents/practiceExams/$(docId)).data.userID == request.auth.uid;
      }

      // Sınav yanıtları - kullanıcı kendi yanıtını yazar
      match /Yanitlar/{userId} {
        allow read: if isAuth();
        allow create, update: if isOwner(userId);
        allow delete: if false;
      }
    }

    // Çıkmış Sorular (admin/system tarafından eklenen içerik)
    match /CikmisSorular/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userID == request.auth.uid;
    }

    // Çıkmış soru verileri
    match /questions/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['viewCount', 'correctCount', 'wrongCount'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;
      match /{sub=**} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    // Soru cevapları - kullanıcı kendi cevabını yazar
    match /questionsAnswers/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && resource.data.userID == request.auth.uid;
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;
    }

    // Kitapçık Cevapları
    match /KitapcikCevaplari/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userID == request.auth.uid;
    }

    // Cevap Anahtarları — client doğrudan okuyamaz; Cloud Functions Admin SDK kullanır
    match /CevapAnahtarlari/{docId} {
      allow read: if false;   // SECURITY: Admin SDK / Cloud Functions only
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // Sorular (ek koleksiyon)
    match /Sorular/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userID == request.auth.uid;
    }

    // Optik Kodlar
    match /optikForm/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userID == request.auth.uid;
    }

    // Kitaplar / Cevap Anahtarı Kitapları
    match /books/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['viewCount', 'solveCount'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;
      match /{sub=**} {
        allow read: if isAuth();
        allow write: if isAuth();
      }
    }

    // Sınavı Bitenler
    match /SinaviBitenler/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && resource.data.userID == request.auth.uid;
    }

    // ──────────────────────────────────────────────
    // JOBS
    // ──────────────────────────────────────────────
    match /isBul/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['viewCount', 'applicationCount'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;

      match /Applications/{applicantId} {
        allow read: if isAuth();
        allow create: if isOwner(applicantId);
        allow update: if isAuth() && (
          request.auth.uid == applicantId
          || get(/databases/$(database)/documents/isBul/$(docId)).data.userID == request.auth.uid
        );
        allow delete: if isOwner(applicantId);
      }
    }
    match /SavedIsBul/{docId} {
      allow read, write: if isAuth();
    }
    match /educators/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.userID == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.userID == request.auth.uid
        || request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['favorites', 'viewCount', 'applicationCount', 'averageRating', 'reviewCount'])
      );
      allow delete: if isAuth() && resource.data.userID == request.auth.uid;

      match /Applications/{applicantId} {
        allow read: if isAuth();
        allow create: if isOwner(applicantId);
        allow update: if isAuth() && (
          request.auth.uid == applicantId
          || get(/databases/$(database)/documents/educators/$(docId)).data.userID == request.auth.uid
        );
        allow delete: if isOwner(applicantId);
      }

      match /Reviews/{reviewerId} {
        allow read: if isAuth();
        allow create, update, delete: if isOwner(reviewerId);
      }
    }

    // ──────────────────────────────────────────────
    // NOTIFICATIONS
    // ──────────────────────────────────────────────
    match /Bildirimler/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }

    // ──────────────────────────────────────────────
    // REPORTING
    // ──────────────────────────────────────────────
    match /reports/{docId} {
      allow read: if false;
      allow create: if isAuth();
      allow update, delete: if false;
    }
    match /Basvurular/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }

    // ──────────────────────────────────────────────
    // ADMIN / CONFIG
    // ──────────────────────────────────────────────
    // NOTE: Firestore rules path parser can fail on non-ASCII path literals.
    // Keep support for "Yönetim" collection via wildcard segment match.
    match /{adminCollection}/{docId} {
      allow read: if isAuth() && adminCollection == "Yönetim";
      allow write: if false; // Admin SDK only
    }
    match /adminConfig/{docId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }
    match /adminConfig/{docId}/pushReports/{reportId} {
      allow read: if canUseAdminPushBypass();
      allow create: if canUseAdminPushBypass();
      allow delete: if canUseAdminPushBypass();
      allow update: if false;
    }
    match /sliders/{sliderId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();

      match /items/{itemId} {
        allow read: if isAuth();
        allow create, update, delete: if isAdmin();
      }
    }
    match /Analytics/{docId} {
      allow read: if false;
      allow write: if isAuth();

      match /{subcol}/{subDocId} {
        allow read: if false;
        allow create: if isAuth();
        allow update, delete: if false;
      }
    }

    // ──────────────────────────────────────────────
    // PHONE ACCOUNTS (from phone_accounts.rules)
    // ──────────────────────────────────────────────
    match /phoneAccounts/{phone} {
      allow read: if false;

      function isSelfAdd(prev, next) {
        return next.count == prev.count + 1
          && !(request.auth.uid in prev.accounts)
          && (request.auth.uid in next.accounts)
          && next.accounts.size() == prev.accounts.size() + 1
          && (next.limit == prev.limit || next.limit == null)
          && next.count <= (prev.limit != null ? prev.limit : 5);
      }
      function isSelfRemove(prev, next) {
        return next.count == prev.count - 1
          && (request.auth.uid in prev.accounts)
          && !(request.auth.uid in next.accounts)
          && next.accounts.size() == prev.accounts.size() - 1
          && (next.limit == prev.limit || next.limit == null)
          && next.count >= 0;
      }

      allow create: if isAuth()
        && request.resource.data.count == 1
        && request.resource.data.accounts.size() == 1
        && (request.auth.uid in request.resource.data.accounts)
        && (request.resource.data.limit == null || request.resource.data.limit >= 1)
        && request.resource.data.phone == phone;
      allow update: if isAuth()
        && (isSelfAdd(resource.data, request.resource.data)
            || isSelfRemove(resource.data, request.resource.data));
      allow delete: if false;
    }

    // ──────────────────────────────────────────────
    // MISCELLANEOUS
    // ──────────────────────────────────────────────
    match /Hashtags/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /tags/{docId} {
      allow read: if isAuth();
      allow write: if false;
      match /posts/{postId} {
        allow read: if isAuth();
        allow write: if false;
      }
    }
    match /HashTags/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /TurqAppVerified/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /SosyalMedyaLinkleri/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /Sosyal/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /Applications/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /CV/{docId} {
      allow read: if isAuth();
      allow write: if isOwner(docId);
    }
    match /HiddenPosts/{docId} {
      allow read: if false;
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /ProfileVisits/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /Saved/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /Yanitlar/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /Yorumlar/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
    match /List/{docId} {
      allow read: if isAuth();
      allow create: if isOwner(docId) || isDocOwnerFromRequest() || isAdmin();
      allow update, delete: if isOwner(docId) || isDocOwnerFromResource() || isAdmin();
    }
  }
}
