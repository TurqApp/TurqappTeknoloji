rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function canWritePostMedia(postId) {
      return isAuth()
        && firestore.exists(/databases/(default)/documents/Posts/$(postId))
        && firestore.get(/databases/(default)/documents/Posts/$(postId)).data.userID == request.auth.uid;
    }
    function hasMatchingUploaderMetadata() {
      return isAuth()
        && request.resource != null
        && request.resource.metadata != null
        && request.resource.metadata.keys().hasAll(['uploaderUid'])
        && request.resource.metadata.uploaderUid == request.auth.uid;
    }
    function canWriteJobMedia(jobId) {
      return isAuth()
        && (
          (
            firestore.exists(/databases/(default)/documents/isBul/$(jobId))
            && firestore.get(/databases/(default)/documents/isBul/$(jobId)).data.userID == request.auth.uid
          )
          || hasMatchingUploaderMetadata()
        );
    }
    function isPostThumbnailFile(fileName) {
      return fileName == "thumbnail.jpg"
        || fileName == "thumbnail.jpeg"
        || fileName == "thumbnail.png"
        || fileName == "thumbnail.webp";
    }
    function isUidTokenInChatId(chatId) {
      return isAuth()
        && (
          chatId == request.auth.uid
          || chatId.matches(request.auth.uid + '_.*')
          || chatId.matches('.*_' + request.auth.uid)
        );
    }
    function isConversationParticipant(chatId) {
      return isAuth()
        && (
          isUidTokenInChatId(chatId)
          || (
            firestore.exists(/databases/(default)/documents/conversations/$(chatId))
            && (
              (
                firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.participants is list
                && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.participants
              )
              || (
                firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.userID1 is string
                && request.auth.uid == firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.userID1
              )
              || (
                firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.userID2 is string
                && request.auth.uid == firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.userID2
              )
            )
          )
        );
    }

    // User profile images
    match /users/{uid}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isOwner(uid)
                   && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Post HLS playback assets - public read for CDN caching
    match /Posts/{postId}/hls/{allPaths=**} {
      allow read;
      allow write: if false; // Cloud Function only
    }

    // Post media root files
    match /Posts/{postId}/{fileName} {
      allow read: if isPostThumbnailFile(fileName) || isAuth();
      allow write: if !isPostThumbnailFile(fileName)
                   && fileName != "hls"
                   && (canWritePostMedia(postId)
                       || hasMatchingUploaderMetadata())
                   && request.resource.size < 35 * 1024 * 1024; // 35MB video limit
    }
    // Post nested media folders (images/, videos/, thumbnails/, ...)
    match /Posts/{postId}/{folder}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if folder != "hls"
                   && (canWritePostMedia(postId)
                       || hasMatchingUploaderMetadata())
                   && request.resource.size < 35 * 1024 * 1024;
    }

    // Story media (legacy uppercase + current lowercase)
    match /Stories/{uid}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isOwner(uid)
                   && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }
    // Story HLS segments - public read for CDN
    match /stories/{uid}/{storyId}/hls/{allPaths=**} {
      allow read;
      allow write: if false; // Cloud Function only
    }
    match /stories/{uid}/{storyId} {
      allow read: if isAuth();
      allow write: if isOwner(uid)
                   && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }
    match /stories/{uid}/{storyId}/{fileName} {
      allow read: if isAuth();
      allow write: if fileName != "hls"
                   && isOwner(uid)
                   && request.resource.size < 50 * 1024 * 1024;
    }
    match /stories/{uid}/{storyId}/{folder}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if folder != "hls"
                   && isOwner(uid)
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Chat media
    match /Chat/{chatId}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if isConversationParticipant(chatId)
                   && request.resource.size < 25 * 1024 * 1024; // 25MB limit
    }
    match /Mesajlar/{chatId}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if isConversationParticipant(chatId)
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // ChatAssets medya (fotoğraf, video, ses)
    match /ChatAssets/{chatId}/{fileName} {
      allow read: if isConversationParticipant(chatId);
      allow write: if isConversationParticipant(chatId)
                   && request.resource.size < 50 * 1024 * 1024; // 50MB
    }
    match /ChatAssets/{chatId}/{folder}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if folder != "messages"
                   && isConversationParticipant(chatId)
                   && request.resource.size < 50 * 1024 * 1024; // 50MB
    }
    match /ChatAssets/{chatId}/messages/{msgId}/{fileName} {
      allow read: if isConversationParticipant(chatId);
      allow write: if fileName != "hls"
                   && isConversationParticipant(chatId)
                   && request.resource.size < 50 * 1024 * 1024;
    }
    match /ChatAssets/{chatId}/messages/{msgId}/{folder}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if folder != "hls"
                   && isConversationParticipant(chatId)
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Chat HLS segments - public read for CDN
    match /ChatAssets/{chatId}/messages/{msgId}/hls/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if false; // Cloud Function only
    }

    // Practice exam media (new standard path)
    match /practiceExams/{examId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 25 * 1024 * 1024; // 25MB
    }

    // Answer key / book covers
    match /books/{bookId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 10 * 1024 * 1024; // 10MB
    }

    match /slider/{moduleId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 10 * 1024 * 1024;
    }

    match /marketStore/{uid}/{itemId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.auth.uid == uid
                   && request.resource.size < 15 * 1024 * 1024;
    }

    match /scholarships/{folder}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && (folder == "templates"
                       || folder == "images"
                       || folder == "logos")
                   && request.resource.size < 15 * 1024 * 1024;
    }

    match /isBul/{jobId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if canWriteJobMedia(jobId)
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // Public assets (logo, default avatar, etc.)
    match /public/{allPaths=**} {
      allow read;
      allow write: if false;
    }

    // Short manifest index and slot payloads. Client reads only; writes are
    // published by Cloud Functions/Admin SDK.
    match /shortManifest/{date}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Feed manifest slot payloads. Client reads only; writes are published by
    // Cloud Functions/Admin SDK.
    match /feedManifest/{date}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Root-level assets (avatar2.png, logoblack.png)
    match /{fileName} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Default: deny
    match /{allPaths=**} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
