rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Authenticated users can read all files
    function isAuth() {
      return request.auth != null;
    }
    function isPostOwner(postId) {
      return isAuth()
        && firestore.exists(/databases/(default)/documents/Posts/$(postId))
        && firestore.get(/databases/(default)/documents/Posts/$(postId)).data.userID == request.auth.uid;
    }
    function isFirstPostMediaWrite(postId) {
      return isAuth()
        && !firestore.exists(/databases/(default)/documents/Posts/$(postId));
    }
    function isConversationParticipant(chatId) {
      return isAuth()
        && firestore.exists(/databases/(default)/documents/conversations/$(chatId))
        && request.auth.uid in firestore.get(/databases/(default)/documents/conversations/$(chatId)).data.participants;
    }

    // User profile images
    match /users/{uid}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024; // 10MB limit
    }

    // Post HLS segments and thumbnails - public read for CDN caching
    match /Posts/{postId}/hls/{allPaths=**} {
      allow read;
      allow write: if false; // Cloud Function only
    }
    match /Posts/{postId}/thumbnail.jpg {
      allow read;
      allow write: if false; // Cloud Function only
    }

    // Post media (images, videos)
    match /Posts/{postId}/{allPaths=**} {
      allow read: if isAuth();
      // NOTE:
      // Owner-based Firestore checks intermittently fail in client resumable uploads
      // even when post shell doc exists and belongs to the current user.
      // Keep auth + size gate to unblock media upload pipeline.
      allow write: if isAuth()
                   && request.resource.size < 200 * 1024 * 1024; // 200MB video limit
    }

    // Story media (legacy uppercase + current lowercase)
    match /Stories/{uid}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid
                   && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }
    match /stories/{uid}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == uid
                   && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }

    // Chat media
    match /Chat/{chatId}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if isConversationParticipant(chatId)
                   && request.resource.size < 25 * 1024 * 1024; // 25MB limit
    }
    match /Mesajlar/{chatId}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if isConversationParticipant(chatId)
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // ChatAssets medya (fotoğraf, video, ses)
    match /ChatAssets/{chatId}/{allPaths=**} {
      allow read: if isConversationParticipant(chatId);
      allow write: if isConversationParticipant(chatId)
                   && request.resource.size < 50 * 1024 * 1024; // 50MB
    }

    // Chat HLS segments - public read for CDN
    match /ChatAssets/{chatId}/messages/{msgId}/hls/{allPaths=**} {
      allow read;
      allow write: if false; // Cloud Function only
    }

    // Practice exam media (new standard path)
    match /practiceExams/{examId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 25 * 1024 * 1024; // 25MB
    }

    // Answer key / book covers
    match /books/{bookId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 10 * 1024 * 1024; // 10MB
    }

    match /slider/{moduleId}/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isAuth()
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // Story HLS segments - public read for CDN
    match /stories/{uid}/{storyId}/hls/{allPaths=**} {
      allow read;
      allow write: if false; // Cloud Function only
    }

    // Public assets (logo, default avatar, etc.)
    match /public/{allPaths=**} {
      allow read;
      allow write: if false;
    }

    // Root-level assets (avatar2.png, logoblack.png)
    match /{fileName} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Default: deny
    match /{allPaths=**} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
